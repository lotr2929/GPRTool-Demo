    .plant-src-badge.field { background:#1a3d1a; color:#7fc47f; border:1px solid #2e6b2e; }
    .plant-src-badge.ornl  { background:#2a2a1a; color:#c4b47f; border:1px solid #5a5010; }
    .plant-src-badge.lit   { background:#1a1a2a; color:#7f9fc4; border:1px solid #2a3a5a; }
    #plant-modal-footer {
