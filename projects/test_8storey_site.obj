# GPRTool Test Model — 8-Storey Building with Sloping Site
#
# Building: 20m x 15m tower, 24m tall (8 storeys x 3m), 45° sloping roof
# Podium:   30m x 25m footprint, 4.5m tall
# Site:     60m x 50m ground plane, sloping 3m rise south to north
#
# Sloping roof: 45° pitch over 15m span → ridge height = 7.5m above eaves
# Eaves at Y=30, ridge at Y=37.5, running east-west along Z=0
#
# Units: metres

# ============================================================
# VERTICES
# ============================================================

# Site corners (sloped: south Y=0, north Y=3)
v -30.0   0.0 -25.0    #  1 site SW
v  30.0   0.0 -25.0    #  2 site SE
v  30.0   3.0  25.0    #  3 site NE
v -30.0   3.0  25.0    #  4 site NW

# Podium base (Y=-2.0) — underground, below site surface
v -15.0  -2.0 -12.5    #  5 podium base SW
v  15.0  -2.0 -12.5    #  6 podium base SE
v  15.0  -2.0  12.5    #  7 podium base NE
v -15.0  -2.0  12.5    #  8 podium base NW

# Podium top (Y=6.0)
v -15.0   6.0 -12.5    #  9 podium top SW
v  15.0   6.0 -12.5    # 10 podium top SE
v  15.0   6.0  12.5    # 11 podium top NE
v -15.0   6.0  12.5    # 12 podium top NW

# Tower base (Y=6.0)
v -10.0   6.0  -7.5    # 13 tower base SW
v  10.0   6.0  -7.5    # 14 tower base SE
v  10.0   6.0   7.5    # 15 tower base NE
v -10.0   6.0   7.5    # 16 tower base NW

# Tower eaves (Y=30.0) — top of walls
v -10.0  30.0  -7.5    # 17 tower eave SW
v  10.0  30.0  -7.5    # 18 tower eave SE
v  10.0  30.0   7.5    # 19 tower eave NE
v -10.0  30.0   7.5    # 20 tower eave NW

# Roof ridge (Y=37.5) — 45 degree pitch, ridge runs east-west along Z=0
v -10.0  37.5   0.0    # 21 ridge west
v  10.0  37.5   0.0    # 22 ridge east

# ============================================================
# FACES — one named object per face, no normals (computed by GPRTool)
# Winding: CCW when viewed from outside/above
# ============================================================

o Site_Ground
f 1 4 3 2

o Podium_Wall_South
f 5 6 10 9

o Podium_Wall_East
f 6 7 11 10

o Podium_Wall_North
f 7 8 12 11

o Podium_Wall_West
f 8 5 9 12

o Podium_Roof
f 9 10 11 12

o Tower_Wall_South
f 13 14 18 17

o Tower_Wall_East
f 14 15 19 18

o Tower_Wall_North
f 15 16 20 19

o Tower_Wall_West
f 16 13 17 20

# Gable ends (triangular) — south and north
o Tower_Gable_South
f 17 18 22 21

o Tower_Gable_North
f 19 20 21 22

# Roof slopes — south face and north face
o Tower_Roof_South
f 17 21 22 18

o Tower_Roof_North
f 20 19 22 21
