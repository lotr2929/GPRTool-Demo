# GPRTool Test Object — Simple Cube
# 10m x 10m x 10m cube centred at origin (X=0, Z=0), base at Y=0
# Units: metres
# Format: Wavefront OBJ

# Vertices — 8 corners of a 10x10x10 cube
# Base (Y=0)
v -5.0  0.0 -5.0
v  5.0  0.0 -5.0
v  5.0  0.0  5.0
v -5.0  0.0  5.0
# Top (Y=10)
v -5.0 10.0 -5.0
v  5.0 10.0 -5.0
v  5.0 10.0  5.0
v -5.0 10.0  5.0

# Normals
vn  0.0  0.0 -1.0
vn  1.0  0.0  0.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

# Object name
o Cube_10m

# Faces (CCW winding, 1-indexed)
# South face (Z = -5)
f 1//1 2//1 6//1 5//1
# East face (X = +5)
f 2//2 3//2 7//2 6//2
# North face (Z = +5)
f 3//3 4//3 8//3 7//3
# West face (X = -5)
f 4//4 1//4 5//4 8//4
# Top face (Y = +10)
f 5//5 6//5 7//5 8//5
# Bottom face (Y = 0)
f 4//6 3//6 2//6 1//6
